generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Provinces
model Province {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  schools     School[]
  applications Application[]
}

// Schools
model School {
  id          String   @id @default(uuid())
  name        String   @unique
  provinceId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  province    Province @relation(fields: [provinceId], references: [id])
  applications Application[]
  users       User[]
}

// Pending Applications
model Application {
  id             String            @id @default(uuid())
  fullName       String
  dateOfBirth    DateTime
  grade          String
  previousSchool String?
  parentName     String?
  parentPhone    String?
  parentEmail    String?
  address        String?
  applicantEmail String
  provinceId     String
  schoolId       String
  status         ApplicationStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  province       Province @relation(fields: [provinceId], references: [id])
  school         School   @relation(fields: [schoolId], references: [id])

  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// Users
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       Role     @default(STUDENT)
  fullName   String?
  grade      String?
  schoolId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  school     School?  @relation(fields: [schoolId], references: [id])

  // Who uploaded
  uploadedReportCards ReportCard[] @relation("ReportCardUploader")
  uploadedMaterials   Material[]   @relation("MaterialUploader")
  uploadedBehavior    BehaviorReport[] @relation("BehaviorUploader")

  // Student-owned records
  reportCards   ReportCard[]   @relation("StudentReportCards")
  materials     Material[]     @relation("StudentMaterials")
  behaviorReports BehaviorReport[] @relation("StudentBehaviorReports")

  @@index([schoolId, role])
  @@map("users")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

// Report Cards
model ReportCard {
  id          String   @id @default(uuid())
  studentId   String
  title       String
  fileUrl     String
  term        String?
  year        Int?     // ✅ ADD THIS LINE
  uploadedBy  String
  uploadedAt  DateTime @default(now())
  
  student     User     @relation("StudentReportCards", fields: [studentId], references: [id])
  uploader    User     @relation("ReportCardUploader", fields: [uploadedBy], references: [id])

  @@map("report_cards")
}

// Learning Materials
model Material {
  id          String    @id @default(uuid())
  studentId   String?   // null for grade-wide materials
  grade       String?
  subject     String
  title       String
  fileUrl     String
  uploadedBy  String
  uploadedAt  DateTime  @default(now())

  student     User?     @relation("StudentMaterials", fields: [studentId], references: [id])
  uploader    User      @relation("MaterialUploader", fields: [uploadedBy], references: [id])

  @@map("materials")
}

// Behavior Reports
model BehaviorReport {
  id          String    @id @default(uuid())
  studentId   String
  date        DateTime
  description String
  severity    String?
  uploadedBy  String
  uploadedAt  DateTime  @default(now())

  student     User      @relation("StudentBehaviorReports", fields: [studentId], references: [id])
  uploader    User      @relation("BehaviorUploader", fields: [uploadedBy], references: [id])

  @@map("behavior_reports")
}